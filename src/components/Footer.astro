---
import { getSiteSettings } from "../lib/appwrite";

const defaults = {
  phone:     '(43) 3377-1900',
  address:   'Av. Rio de Janeiro, 1500 — 8º Andar',
  city:      'Sala 803. Centro, Londrina',
  instagram: '',
  facebook:  '',
  youtube:   '',
  linkedin:  '',
};

const doc = await getSiteSettings();
let cfg = { ...defaults };

if (doc) {
  Object.keys(defaults).forEach(k => { if (doc[k]) cfg[k] = doc[k]; });
}

// Monta lista de sociais apenas com URLs preenchidas
const sociais = [
  { url: cfg.facebook,  label: 'Facebook',  icon: `<path d="M12 2.04c-5.5 0-10 4.49-10 10.02 0 5 3.66 9.15 8.44 9.9v-7h-2.54v-2.9h2.54V10.1c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 008.44-9.9c0-5.53-4.5-10.02-10-10.02z"/>` },
  { url: cfg.instagram, label: 'Instagram', icon: `<path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2m-.2 2A3.6 3.6 0 004 7.6v8.8A3.6 3.6 0 007.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6A3.6 3.6 0 0016.4 4H7.6m9.65 1.5a1.25 1.25 0 011.25 1.25A1.25 1.25 0 0117.25 8 1.25 1.25 0 0116 6.75a1.25 1.25 0 011.25-1.25M12 7a5 5 0 015 5 5 5 0 01-5 5 5 5 0 01-5-5 5 5 0 015-5m0 2a3 3 0 00-3 3 3 3 0 003 3 3 3 0 003-3 3 3 0 00-3-3z"/>` },
  { url: cfg.youtube,   label: 'YouTube',   icon: `<path d="M10 15l5.19-3L10 9v6m11.56-7.83c.13.47.22 1.1.28 1.9.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83-.25.9-.83 1.48-1.73 1.73-.47.13-1.33.22-2.65.28-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44-.9-.25-1.48-.83-1.73-1.73-.13-.47-.22-1.1-.28-1.9-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83.25-.9.83-1.48 1.73-1.73.47-.13 1.33-.22 2.65-.28 1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44.9.25 1.48.83 1.73 1.73z"/>` },
  { url: cfg.linkedin,  label: 'LinkedIn',  icon: `<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>` },
].filter(s => s.url);
---

<footer class="footer">
  <div class="footer__main">
    <div class="container footer__grid">
      <div class="footer__brand">
        <img
          src="/img/logo-i-200px.jpg"
          alt="Logo Spazio Vascolare"
          class="footer__logo"
        />
      </div>

      <div class="footer__info">
        <div class="footer__item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="footer__icon">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <div class="footer__text">
            <span>{cfg.address}</span>
            <span>{cfg.city}</span>
            <div class="footer__contact">
              <strong>Fone: {cfg.phone}</strong>
            </div>
          </div>
        </div>
      </div>

      <div class="footer__social">
        {sociais.map(s => (
          <a href={s.url} class="social-item" target="_blank" rel="noopener noreferrer" aria-label={s.label}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon} />
            <span>{s.label}</span>
          </a>
        ))}
        {sociais.length === 0 && (
          <span style="font-size:0.8rem;opacity:0.5">Redes sociais não configuradas</span>
        )}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__legal">
      <a href="#" class="legal-link">Políticas de Privacidade</a>
      <span class="copyright">Copyright © Dra. Mônica Arena</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    display: flex;
    flex-direction: column;
    width: 100%;
    margin-top: 2rem;
  }

  .footer__main {
    background: #410213;
    padding-block: 2.5rem;
    color: #fff;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 200px 1fr 200px;
    align-items: center;
    gap: 3rem;
  }

  .footer__logo {
    width: 150px;
    height: auto;
    border-radius: 8px;
  }

  .footer__info {
    justify-self: center;
    text-align: center;
  }

  .footer__item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    text-align: left; /* Mantém o texto alinhado ao ícone */
  }

  .footer__icon {
    color: #fff;
    margin-top: 0.2rem;
  }

  .footer__text {
    display: flex;
    flex-direction: column;
    font-size: 0.9rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .footer__contact {
    margin-top: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .footer__social {
    justify-self: end;
    display: flex;
    gap: 3rem;
  }

  .social-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    transition: transform var(--dur) var(--ease);
  }

  .social-item:hover {
    transform: translateY(-4px);
    color: #f3c3d3;
  }

  .social-item span {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .footer__bottom {
    background: #f3c3d3;
    padding-block: 1.5rem;
    color: #410213;
    text-align: center;
  }

  .footer__legal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .legal-link {
    text-decoration: none;
    color: inherit;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .copyright {
    font-size: 0.8rem;
    opacity: 0.9;
  }

  /* Mobile */
  @media (max-width: 968px) {
    .footer__grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .footer__logo {
      margin-inline: auto;
    }
    .footer__item {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer__social {
      justify-self: center;
    }
  }
</style>
