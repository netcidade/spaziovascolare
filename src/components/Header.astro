---

<header class="header glass" id="header">
  <div class="container header__inner">
    <a href="/" class="logo">
      <img src="/img/logo-i-200px.jpg" alt="Logo" class="logo__img" />
      <div class="logo__brand">
        <span class="logo__text">SPAZIO</span>
        <span class="logo__text">VASCOLARE</span>
      </div>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <ul class="nav__list">
        <li><a href="/" class="nav__link">Início</a></li>
        <li><a href="/#sobre" class="nav__link">Sobre</a></li>
        <li><a href="/tratamentos" class="nav__link">Tratamentos</a></li>
        <li><a href="/cirurgias/" class="nav__link">Cirurgias</a></li>
        <li class="nav__item-with-dropdown">
          <a href="/blog/" class="nav__link">Blog</a>
          <ul class="nav__dropdown">
            <li><a href="/blog/categoria/Saúde Vascular">Saúde Vascular</a></li>
            <li><a href="/blog/categoria/Tratamentos">Tratamentos</a></li>
            <li><a href="/blog/categoria/Cirurgia">Cirurgia</a></li>
            <li><a href="/blog/categoria/Prevenção">Prevenção</a></li>
          </ul>
        </li>
      </ul>
    </nav>
    <div class="header__actions">
      <a href="https://wa.me/5543991502223" class="btn-tech desktop-only">
        Agendar
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14m-7-7 7 7-7 7"></path>
        </svg>
      </a>
      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay - FORA do header para o fundo branco funcionar -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__header">
      <span class="logo__text">MENU</span>
      <button class="menu-close" id="menuClose">&times;</button>
    </div>
    <nav class="mobile-nav">
      <ul>
        <li><a href="/">Início</a></li>
        <li><a href="/#sobre">Sobre</a></li>
        <li><a href="/tratamentos">Tratamentos</a></li>
        <li><a href="/cirurgias/">Cirurgias</a></li>
        <li><a href="/blog/">Blog</a></li>
      </ul>
    </nav>
    <div class="mobile-menu__footer">
      <a href="https://wa.me/5543991502223" class="btn-tech" style="width: 100%; justify-content: center; display: flex;">
        Agendar Consulta
      </a>
    </div>
  </div>
</div>

<style>
  .header {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(90%, 1200px);
    z-index: 1000;
    padding: 0.75rem 2rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.4);
    transition: all 0.4s var(--ease);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100% !important;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }

  .logo__img {
    height: 48px;
    width: auto;
    border-radius: 8px;
    transition: transform 0.3s var(--ease);
  }

  .logo__brand {
    display: flex;
    flex-direction: column;
  }

  .logo__text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    line-height: 1.1;
    color: var(--text);
  }

  .nav__list {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav__link {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: color 0.3s;
  }

  .nav__link:hover {
    color: var(--accent);
  }

  /* Dropdown no desktop */
  .nav__item-with-dropdown {
    position: relative;
  }
  .nav__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #fff;
    border: 1px solid rgba(212, 10, 91, 0.1);
    border-radius: 12px;
    padding: 0.75rem 0;
    min-width: 180px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s var(--ease);
    list-style: none;
    z-index: 100;
  }
  .nav__item-with-dropdown:hover .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .nav__dropdown li a {
    display: block;
    padding: 0.5rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav__dropdown li a:hover {
    background: rgba(212, 10, 91, 0.05);
    color: var(--accent);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--accent);
    cursor: pointer;
    padding: 0.5rem;
  }

  /* Mobile Menu - 100% Sólido */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s;
  }

  .mobile-menu.active {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu__inner {
    position: absolute;
    top: 0;
    right: 0;
    width: 85%;
    max-width: 380px;
    height: 100%;
    background: #ffffff !important; /* Branco puro e sólido */
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0.2);
  }

  .mobile-menu.active .mobile-menu__inner {
    transform: translateX(0);
  }

  .mobile-menu__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding-bottom: 1rem;
  }

  .menu-close {
    background: none;
    border: none;
    font-size: 2.5rem;
    color: var(--accent);
    cursor: pointer;
    line-height: 1;
  }

  .mobile-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mobile-nav li {
    border-bottom: 1px solid rgba(0, 0, 0, 0.03);
  }
  .mobile-nav a {
    text-decoration: none;
    color: var(--text);
    font-size: 1.2rem;
    font-weight: 700;
    font-family: var(--font-display);
    padding: 1.2rem 0;
    display: block;
  }

  .mobile-menu__footer {
    margin-top: auto;
    padding-top: 2rem;
  }

  @media (max-width: 1024px) {
    .nav, .desktop-only {
      display: none;
    }
    .menu-toggle {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .header {
      width: 95%;
      padding: 0.5rem 1.25rem;
    }
    .logo__brand { display: none; }
  }
</style>

<script>
  const header = document.getElementById("header");
  const menuToggle = document.getElementById("menuToggle");
  const menuClose = document.getElementById("menuClose");
  const mobileMenu = document.getElementById("mobileMenu");

  // Scroll effect
  window.addEventListener("scroll", () => {
    if (header) {
      if (window.scrollY > 50) {
        header.style.background = "rgba(255, 255, 255, 0.95)";
        header.style.top = "1rem";
      } else {
        header.style.background = "rgba(255, 255, 255, 0.4)";
        header.style.top = "1.5rem";
      }
    }
  });

  // Mobile menu toggle
  menuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.add("active");
    document.body.style.overflow = "hidden";
  });

  const closeMenu = () => {
    mobileMenu?.classList.remove("active");
    document.body.style.overflow = "";
  };

  menuClose?.addEventListener("click", closeMenu);
  mobileMenu?.addEventListener("click", (e) => {
    if (e.target === mobileMenu) closeMenu();
  });
</script>
