---

---

<header class="header glass" id="header">
  <div class="container header__inner">
    <a href="/" class="logo">
      <img src="/img/logo-i-200px.jpg" alt="Logo" class="logo__img" />
      <div class="logo__brand">
        <span class="logo__text">SPAZIO</span>
        <span class="logo__text">VASCOLARE</span>
      </div>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <ul class="nav__list">
        <li><a href="/" class="nav__link">Início</a></li>
        <li><a href="/#sobre" class="nav__link">Sobre</a></li>
        <li><a href="/tratamentos" class="nav__link">Tratamentos</a></li>
        <li><a href="/cirurgias/" class="nav__link">Cirurgias</a></li>
        <li class="nav__item-with-dropdown">
          <a href="/blog/" class="nav__link">Blog</a>
          <ul class="nav__dropdown">
            <li><a href="/blog/categoria/Saúde Vascular">Saúde Vascular</a></li>
            <li><a href="/blog/categoria/Tratamentos">Tratamentos</a></li>
            <li><a href="/blog/categoria/Cirurgia">Cirurgia</a></li>
            <li><a href="/blog/categoria/Prevenção">Prevenção</a></li>
          </ul>
        </li>
      </ul>
    </nav>
    <div class="header__actions">
      <a href="https://wa.me/5543991502223" class="btn-tech">
        Agendar
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M5 12h14m-7-7 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(90%, 1200px);
    z-index: 1000;
    padding: 0.75rem 2rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.4);
    transition: all var(--dur) var(--ease);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100% !important;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    position: relative;
  }

  .logo__img {
    height: 56px;
    width: auto;
    border-radius: 8px;
    transition: transform var(--dur) var(--ease);
    margin: -10px 0; /* Permite que a imagem transborde levemente sem aumentar o menu */
  }

  .logo__brand {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .logo__text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    line-height: 1.1;
    color: var(--text);
  }

  .logo:hover .logo__img {
    transform: scale(1.05);
  }

  .nav__list {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav__link {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: color var(--dur) var(--ease);
  }

  .nav__link:hover {
    color: var(--accent);
  }

  /* Dropdown */
  .nav__item-with-dropdown {
    position: relative;
  }

  .nav__dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #fff;
    border: 1px solid rgba(212, 10, 91, 0.1);
    border-radius: 12px;
    padding: 0.75rem 0;
    min-width: 180px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s var(--ease);
    list-style: none;
    z-index: 100;
  }

  .nav__item-with-dropdown:hover .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav__dropdown li a {
    display: block;
    padding: 0.5rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .nav__dropdown li a:hover {
    background: rgba(212, 10, 91, 0.05);
    color: var(--accent);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav {
      display: none;
    }
  }
</style>

<script>
  // Simple scroll effect
  const header = document.getElementById("header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.style.padding = "0.5rem 1.5rem";
      header.style.background = "rgba(255, 255, 255, 0.8)";
    } else {
      header.style.padding = "0.75rem 2rem";
      header.style.background = "var(--surface-glass)";
    }
  });
</script>
