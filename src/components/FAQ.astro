---
import { getQuizzes } from "../lib/appwrite";

interface Props {
  page: string;
  title?: string;
  subtitle?: string;
}

const { page, title = "Dúvidas Frequentes", subtitle = "Esclareça suas principais dúvidas" } = Astro.props;

let faqs = [];
try {
  faqs = await getQuizzes(page);
} catch (e) {
  console.error("Erro ao buscar FAQ:", e);
}
---

{faqs && faqs.length > 0 && (
  <section class="faq-section" id={`faq-${page}`}>
    <div class="container">
      <div class="faq-main-card glass">
        <div class="section-header">
          <div class="section-meta">FAQ</div>
          <h2 class="faq-title">{title}<br /><span class="text-gradient">{subtitle}</span></h2>
        </div>

        <div class="faq-list">
          {faqs.map((faq, i) => (
            <details class="faq-item" data-index={i}>
              <summary class="faq-item__q">
                {faq.question}
                <svg class="faq-item__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <p class="faq-item__a">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .faq-section { 
    padding-block: 6rem;
    position: relative;
  }

  .faq-main-card {
    padding: 5rem;
    border-radius: 40px;
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .faq-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 3.5rem;
    line-height: 1.1;
  }

  .faq-list { 
    display: flex; 
    flex-direction: column; 
    gap: 0.5rem; 
    width: 100%;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    transition: all 0.3s var(--ease);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-item__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    cursor: pointer;
    list-style: none;
  }

  .faq-item__q::-webkit-details-marker { display: none; }

  .faq-item__q:hover { color: var(--accent); }
  
  .faq-item[open] .faq-item__q { 
    color: var(--accent); 
    border-bottom: 1px solid rgba(212, 10, 91, 0.1);
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
  }
  
  .faq-item[open] .faq-item__icon { transform: rotate(180deg); color: var(--accent); }

  .faq-item__icon { 
    transition: transform 0.4s var(--ease); 
    flex-shrink: 0; 
    color: var(--text-muted);
  }

  .faq-item__a {
    padding: 0 0 1.5rem;
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    animation: slideDown 0.4s var(--ease);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .faq-main-card { padding: 2rem; border-radius: 30px; }
    .faq-item__q { padding: 1.25rem 0.5rem; font-size: 1rem; }
    .faq-item__a { padding: 1.25rem 0.5rem; }
  }
</style>
