---

---

<section class="hero" id="inicio">
  <div class="container hero__content">
    <div class="hero__text">
      <div class="section-meta">Tecnologia & Precisão Vascular</div>

      <h1 class="hero__title">
        O Futuro do<br />
        <span class="text-gradient">Cuidado Vascular</span><br />
        é Agora.
      </h1>

      <p class="hero__desc">
        Combinando excelência técnica com inovação internacional (Fellowship
        Arizona, EUA) para oferecer tratamentos minimamente invasivos e
        resultados estéticos superiores.
      </p>

      <div class="hero__actions">
        <a href="#contato" class="btn-tech">
          Agendar Consulta
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14m-7-7 7 7-7 7"></path>
          </svg>
        </a>
        <a href="#tratamentos" class="btn-secondary"> Explorar Tecnologias </a>
      </div>

      <div class="hero__stats">
        <div class="floating-badge hero-badge glass">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2"
          >
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
            ></path>
          </svg>
          <div>
            <strong>15+ Anos</strong>
            <span>de Expertise</span>
          </div>
        </div>

        <div class="floating-badge hero-badge glass">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent)"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path
              d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10M12 2a15.3 15.3 0 0 0-4 10 15.3 15.3 0 0 0 4 10"
            ></path>
          </svg>
          <div>
            <strong>USA</strong>
            <span>Fellowship Int.</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      <div class="image-frame">
        <img
          src="https://spaziovascolare.com.br/wp-content/uploads/2023/02/foto-dra-removed-bg-1.png"
          alt="Dra. Mônica Arena"
          class="hero__image"
        />
        <div class="floating-badge glass">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--accent-pulse)"
            stroke-width="2"
          >
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
          <div>
            <strong>Cirurgia Vascular</strong>
            <span>Londrina — PR</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 6rem 2rem 6rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: start;
    padding-top: 1rem;
  }

  .hero__title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    margin-bottom: 2rem;
    color: var(--text);
    line-height: 1;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--accent) 0%, #ff4d94 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 4px rgba(212, 10, 91, 0.1));
  }

  .hero__desc {
    font-size: 1.15rem;
    font-weight: 500;
    margin-bottom: 1rem;
    max-width: 50ch;
    color: var(--text);
  }

  .hero__actions {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.5);
    transition: all var(--dur) var(--ease);
  }

  .btn-secondary:hover {
    background: #fff;
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(212, 10, 91, 0.05);
  }

  .hero__stats {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .hero-badge {
    position: relative !important;
    bottom: auto !important;
    left: auto !important;
    background: rgba(255, 255, 255, 0.4) !important;
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 0.75rem 1.25rem !important;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* Visuals */
  .hero__visual {
    position: relative;
  }

  .image-frame {
    position: relative;
    padding: 2rem;
    border-radius: 40px;
    background: rgba(255, 255, 255, 0.3);
  }

  .hero__image {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 40px rgba(212, 10, 91, 0.1));
  }

  .floating-badge {
    position: absolute;
    bottom: 4rem;
    left: -2rem;
    background: rgba(255, 255, 255, 0.8) !important;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: 0 10px 30px rgba(212, 10, 91, 0.08);
  }

  .floating-badge strong {
    display: block;
    font-size: 0.85rem;
    color: var(--text);
  }

  .floating-badge span {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  /* Mobile */
  @media (max-width: 1024px) {
    .hero {
      padding: 4rem 1rem 1rem 1rem;
    }

    .hero__content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1rem;
    }

    .hero__text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero__actions {
      flex-direction: column;
      width: 100%;
      gap: 1rem;
    }

    .btn-tech,
    .btn-secondary {
      width: 100%;
      justify-content: center;
    }

    .hero__stats {
      flex-direction: column;
      width: 100%;
    }

    .hero-badge {
      width: 100%;
      font-size: 12px;
      line-height: 1.2rem;
      margin-bottom: 0.5rem;
      justify-content: center;
    }

    .hero__visual {
      order: -1;
      max-width: 320px;
      margin-inline: auto;
      margin-bottom: 0rem;
    }

    .floating-badge {
      position: relative;
      bottom: auto;
      left: auto;
      margin-top: -1.5rem;
      z-index: 2;
      justify-content: center;
    }
  }
</style>
