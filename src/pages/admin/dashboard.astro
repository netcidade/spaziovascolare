    <div class="toast-container" id="toasts"></div>

    <script>
      import {
        call,
        slugify,
        toast,
        uniqueId,
        loadStats,
        loadAll,
        loadSettings,
        initTabs,
        initEditors,
      } from "../../lib/dashboard-api.ts";
      import { DATABASE_ID, COLLECTIONS } from "../../lib/appwrite.ts";

      const SETTINGS_DOC_ID = "main";

      // INIT
      (async () => {
        try {
          const user = await call("/account");
          const emailEl = document.getElementById("userEmail");
          if (emailEl) emailEl.textContent = user.email;
          document.getElementById("loader")?.classList.add("hidden");
          initTabs();
          initEditors();
          loadStats();
          loadAll();
          loadSettings();
        } catch (e) {
          window.location.href = "/admin";
        }
      })();

      // UTILS
      window.openModal = (id) =>
        document.getElementById(id).classList.add("open");
      window.closeModal = (id) =>
        document.getElementById(id).classList.remove("open");
      
      // CARD NAVIGATION
      document.querySelectorAll('.stat-card[data-goto]').forEach(card => {
        card.addEventListener('click', () => {
          const tab = (card as HTMLElement).dataset.goto;
          const btn = document.querySelector(`.nav-link[data-tab="${tab}"]`);
          if (btn) (btn as HTMLButtonElement).click();
        });
      });

      // MOBILE MENU TOGGLE
      const sidebarEl = document.querySelector('.sidebar');
      const overlayEl = document.getElementById('sidebarOverlay');
      const menuBtnEl = document.getElementById('menuBtn');
      
      function toggleMenu() {
        console.log('Toggling menu...');
        sidebarEl?.classList.toggle('active');
        overlayEl?.classList.toggle('active');
      }
      
      if (menuBtnEl) menuBtnEl.onclick = toggleMenu;
      if (overlayEl) overlayEl.onclick = toggleMenu;
      
      // Auto close menu on tab click (mobile)
      document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 1024) toggleMenu();
        });
      });

      // SLUGS
      ["t", "s", "p"].forEach((x) => {
        document.getElementById(x + "_title")?.addEventListener("input", (e) => {
          const el = document.getElementById(x + "_slug");
          if (el) el.value = slugify((e.target as HTMLInputElement).value);
        });
      });

      // TRATAMENTOS
      window.openT = () => {
        document.getElementById("formT").reset();
        document.getElementById("t_id").value = "";
        window.quillT.setContents([]);
        window.quillSubT.setContents([]);
        document.getElementById("titleT").textContent = "Novo Tratamento";
        openModal("modalT");
      };
      window.editT = (id) => {
        const d = window.dataT.find((x) => x.$id === id);
        if (!d) return;
        document.getElementById("t_id").value = d.$id;
        document.getElementById("t_icon").value = d.icon || "";
        document.getElementById("t_order").value = d.order || 1;
        document.getElementById("t_title").value = d.title;
        document.getElementById("t_slug").value = d.slug || "";
        window.quillSubT.root.innerHTML = d.subtitle || "";
        document.getElementById("t_cover").value = d.cover_url || "";
        window.quillT.root.innerHTML = d.description || "";
        document.getElementById("t_dur").value = d.duration || "";
        document.getElementById("t_rec").value = d.recovery || "";
        document.getElementById("t_active").value = d.active.toString();
        document.getElementById("t_highlight").value = d.highlight.toString();
        openModal("modalT");
      };
      document.getElementById("formT").addEventListener("submit", async (e) => {
        e.preventDefault();
        const id = document.getElementById("t_id").value;
        const data = {
          icon: document.getElementById("t_icon").value,
          order: parseInt(document.getElementById("t_order").value),
          title: document.getElementById("t_title").value,
          slug: document.getElementById("t_slug").value,
          subtitle: window.quillSubT.root.innerHTML,
          cover_url: document.getElementById("t_cover").value,
          description: window.quillT.root.innerHTML,
          duration: document.getElementById("t_dur").value,
          recovery: document.getElementById("t_rec").value,
          active: document.getElementById("t_active").value === "true",
          highlight: document.getElementById("t_highlight").value === "true",
        };
        try {
          if (id)
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.TREATMENTS}/documents/${id}`,
              { method: "PATCH", body: JSON.stringify({ data }) },
            );
          else
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.TREATMENTS}/documents`,
              {
                method: "POST",
                body: JSON.stringify({
                  documentId: uniqueId(),
                  data,
                  permissions: [],
                }),
              },
            );
          toast("Salvo!");
          closeModal("modalT");
          loadAll();
          loadStats();
        } catch (e) {
          toast("Erro");
        }
      });

      // CIRURGIAS
      window.openS = () => {
        document.getElementById("formS").reset();
        document.getElementById("s_id").value = "";
        window.quillS.setContents([]);
        window.quillSubS.setContents([]);
        document.getElementById("titleS").textContent = "Nova Cirurgia";
        openModal("modalS");
      };
      window.editS = (id) => {
        const d = window.dataS.find((x) => x.$id === id);
        if (!d) return;
        document.getElementById("s_id").value = d.$id;
        document.getElementById("s_num").value = d.number || "";
        document.getElementById("s_order").value = d.order || 1;
        document.getElementById("s_title").value = d.title;
        document.getElementById("s_slug").value = d.slug || "";
        window.quillSubS.root.innerHTML = d.subtitle || "";
        document.getElementById("s_cover").value = d.cover_url || "";
        window.quillS.root.innerHTML = d.description || "";
        document.getElementById("s_dur").value = d.duration || "";
        document.getElementById("s_rec").value = d.recovery || "";
        document.getElementById("s_ane").value = d.anesthesia || "";
        document.getElementById("s_active").value = d.active.toString();
        openModal("modalS");
      };
      document.getElementById("formS").addEventListener("submit", async (e) => {
        e.preventDefault();
        const id = document.getElementById("s_id").value;
        const data = {
          number: document.getElementById("s_num").value,
          order: parseInt(document.getElementById("s_order").value),
          title: document.getElementById("s_title").value,
          slug: document.getElementById("s_slug").value,
          subtitle: window.quillSubS.root.innerHTML,
          cover_url: document.getElementById("s_cover").value,
          description: window.quillS.root.innerHTML,
          duration: document.getElementById("s_dur").value,
          recovery: document.getElementById("s_rec").value,
          anesthesia: document.getElementById("s_ane").value,
          active: document.getElementById("s_active").value === "true",
        };
        try {
          if (id)
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.SURGERIES}/documents/${id}`,
              { method: "PATCH", body: JSON.stringify({ data }) },
            );
          else
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.SURGERIES}/documents`,
              {
                method: "POST",
                body: JSON.stringify({
                  documentId: uniqueId(),
                  data,
                  permissions: [],
                }),
              },
            );
          toast("Salvo!");
          closeModal("modalS");
          loadAll();
          loadStats();
        } catch (e) {
          toast("Erro");
        }
      });

      // BLOG
      window.openP = () => {
        document.getElementById("formP").reset();
        document.getElementById("p_id").value = "";
        window.quillP.setContents([]);
        window.quillExc.setContents([]);
        openModal("modalP");
      };
      window.editP = (id) => {
        const d = window.dataP.find((x) => x.$id === id);
        if (!d) return;
        document.getElementById("p_id").value = d.$id;
        document.getElementById("p_title").value = d.title;
        document.getElementById("p_slug").value = d.slug;
        window.quillExc.root.innerHTML = d.excerpt || "";
        window.quillP.root.innerHTML = d.content || "";
        document.getElementById("p_cat").value = d.category;
        document.getElementById("p_date").value = d.published_at
          ? d.published_at.split("T")[0]
          : "";
        document.getElementById("p_img").value = d.cover_url || "";
        document.getElementById("p_pub").value = d.published.toString();
        openModal("modalP");
      };
      document.getElementById("formP").addEventListener("submit", async (e) => {
        e.preventDefault();
        const id = document.getElementById("p_id").value;
        const data = {
          title: document.getElementById("p_title").value,
          slug: document.getElementById("p_slug").value,
          excerpt: window.quillExc.root.innerHTML,
          content: window.quillP.root.innerHTML,
          category: document.getElementById("p_cat").value,
          published_at: document.getElementById("p_date").value
            ? new Date(document.getElementById("p_date").value).toISOString()
            : new Date().toISOString(),
          cover_url: document.getElementById("p_img").value,
          published: document.getElementById("p_pub").value === "true",
        };
        try {
          if (id)
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.POSTS}/documents/${id}`,
              { method: "PATCH", body: JSON.stringify({ data }) },
            );
          else
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.POSTS}/documents`,
              {
                method: "POST",
                body: JSON.stringify({
                  documentId: uniqueId(),
                  data,
                  permissions: [],
                }),
              },
            );
          toast("Salvo!");
          closeModal("modalP");
          loadAll();
          loadStats();
        } catch (e) {
          toast("Erro");
        }
      });

      // QUIZ
      window.openQ = () => {
        document.getElementById("formQ").reset();
        document.getElementById("q_id").value = "";
        openModal("modalQ");
      };
      window.editQ = (id) => {
        const d = window.dataQ.find((x) => x.$id === id);
        if (!d) return;
        document.getElementById("q_id").value = d.$id;
        document.getElementById("q_page").value = d.page;
        document.getElementById("q_order").value = d.order || 1;
        document.getElementById("q_question").value = d.question;
        document.getElementById("q_answer").value = d.answer;
        document.getElementById("q_active").value = d.active.toString();
        openModal("modalQ");
      };
      document.getElementById("formQ").addEventListener("submit", async (e) => {
        e.preventDefault();
        const id = document.getElementById("q_id").value;
        const data = {
          page: document.getElementById("q_page").value,
          order: parseInt(document.getElementById("q_order").value),
          question: document.getElementById("q_question").value,
          answer: document.getElementById("q_answer").value,
          active: document.getElementById("q_active").value === "true",
        };
        try {
          if (id)
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.QUIZ}/documents/${id}`,
              { method: "PATCH", body: JSON.stringify({ data }) },
            );
          else
            await call(
              `/databases/${DATABASE_ID}/collections/${COLLECTIONS.QUIZ}/documents`,
              {
                method: "POST",
                body: JSON.stringify({
                  documentId: uniqueId(),
                  data,
                  permissions: [],
                }),
              },
            );
          toast("Salvo!");
          closeModal("modalQ");
          loadAll();
          loadStats();
        } catch (e) {
          toast("Erro");
        }
      });

      // LOGOUT
      document
        .getElementById("logoutBtn")
        ?.addEventListener("click", async () => {
          try {
            await call("/account/sessions/current", { method: "DELETE" });
          } catch (e) {}
          localStorage.removeItem("cookieFallback");
          window.location.replace("/admin");
        });
    </script>
  </body>
