    <div class="toast-container" id="toasts"></div>

    <script>
      // CONFIG & API
      const ENDPOINT = 'https://appwrite.netcidade.com/v1';
      const PROJECT = 'spazio-vascolare';
      const DB = 'spazio-vascolare';
      const COLLECTIONS = { t: 'tratamentos', s: 'cirurgias', p: 'blog_posts', q: 'quiz', cfg: 'site_settings' };
      const SETTINGS_DOC_ID = 'main'; // ID fixo do documento de configurações

      const EDIT_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
      const DEL_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>`;
      const LINK_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>`;

      const getHeaders = () => ({
        'Content-Type': 'application/json',
        'X-Appwrite-Project': PROJECT,
        'x-fallback-cookies': localStorage.getItem('cookieFallback') || ''
      });

      async function call(path, opts = {}) {
        const res = await fetch(`${ENDPOINT}${path}`, { ...opts, credentials: 'include', headers: { ...getHeaders(), ...opts.headers } });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.message || 'Erro de rede');
        }
        if (res.status === 204) return null;
        return res.json().catch(() => null);
      }

      // Helpers
      function slugify(text) {
        return text.toString().toLowerCase().trim()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '') // Remove acentos
          .replace(/\s+/g, '-') // Espaços para -
          .replace(/[^\w-]+/g, '') // Remove tudo que não é letra/número/-
          .replace(/--+/g, '-'); // Remove duplos --
      }

      function toast(msg) {
        const container = document.getElementById('toasts');
        const el = document.createElement('div');
        el.className = 'toast';
        el.textContent = msg;
        container.appendChild(el);
        setTimeout(() => el.remove(), 3000);
      }

      function uniqueId() { return Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15); }

      // AUTH & INIT
      (async () => {
        try {
          const user = await call('/account');
          document.getElementById('userEmail').textContent = user.email;
          document.getElementById('loader').classList.add('hidden');
          initTabs();
          initEditors();
          loadStats();
          loadAll();
          loadSettings();
        } catch (e) {
          window.location.href = '/admin';
        }
      })();

      const qConfig = {
        theme: 'snow',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['link', 'clean']
          ]
        }
      };
      let quillT, quillS, quillP, quillExc;
      function initEditors() {
        quillT = new Quill('#editorT', qConfig);
        quillS = new Quill('#editorS', qConfig);
        quillP = new Quill('#editorP', qConfig);
        quillExc = new Quill('#editorExc', qConfig);
      }

      function initTabs() {
        const links = document.querySelectorAll('.nav-link[data-tab]');
        links.forEach(l => l.addEventListener('click', () => {
          links.forEach(x => x.classList.remove('active'));
          l.classList.add('active');
          const tab = l.dataset.tab;
          document.querySelectorAll('.tab-section').forEach(s => s.classList.remove('active'));
          document.getElementById(`tab-${tab}`).classList.add('active');
          document.getElementById('tabTitle').textContent = l.textContent;
        }));
      }

      // Auto-slug listeners
      document.getElementById('t_title')?.addEventListener('input', (e) => {
        document.getElementById('t_slug').value = slugify(e.target.value);
      });
      document.getElementById('s_title')?.addEventListener('input', (e) => {
        document.getElementById('s_slug').value = slugify(e.target.value);
      });
      document.getElementById('p_title')?.addEventListener('input', (e) => {
        document.getElementById('p_slug').value = slugify(e.target.value);
      });

      // DATA LOADING
      window.loadStats = async function() {
        try {
          const [t, s, p, q] = await Promise.all([
            call(`/databases/${DB}/collections/${COLLECTIONS.t}/documents?limit=0`),
            call(`/databases/${DB}/collections/${COLLECTIONS.s}/documents?limit=0`),
            call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents?limit=0`),
            call(`/databases/${DB}/collections/${COLLECTIONS.q}/documents?limit=0`)
          ]);
          document.getElementById('count-t').textContent = t.total;
          document.getElementById('count-s').textContent = s.total;
          document.getElementById('count-p').textContent = p.total;
          document.getElementById('count-q').textContent = q.total;
        } catch (e) {}
      }

      let dataT = [], dataS = [], dataP = [], dataQ = [];

      window.loadAll = async function() {
        try {
          const [t, s, p, q] = await Promise.all([
            call(`/databases/${DB}/collections/${COLLECTIONS.t}/documents?limit=100&orderAttributes[]=order&orderTypes[]=ASC`),
            call(`/databases/${DB}/collections/${COLLECTIONS.s}/documents?limit=100&orderAttributes[]=order&orderTypes[]=ASC`),
            call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents?limit=100&orderAttributes[]=%24createdAt&orderTypes[]=DESC`),
            call(`/databases/${DB}/collections/${COLLECTIONS.q}/documents?limit=100&orderAttributes[]=order&orderTypes[]=ASC`)
          ]);
          dataT = t.documents; dataS = s.documents; dataP = p.documents; dataQ = q.documents;
          renderT(); renderS(); renderP(); renderQ();
        } catch (e) { toast('Erro ao carregar dados'); }
      }

      // RENDERING
      window.renderT = function() {
        document.getElementById('tableT').innerHTML = dataT.map(d => `
          <tr>
            <td style="font-family:var(--font-mono)">${d.order}</td>
            <td style="font-weight:700">${d.title}</td>
            <td style="color:var(--text-muted);font-size:0.8rem">${d.subtitle || '—'}</td>
            <td><span class="badge ${d.active ? 'badge--ok' : 'badge--wait'}">${d.active ? 'Ativo' : 'Off'}</span></td>
            <td>
              <div class="row-actions">
                <button class="btn-icon" onclick="editT('${d.$id}')">${EDIT_SVG}</button>
                <button class="btn-icon" onclick="deleteDoc('${COLLECTIONS.t}', '${d.$id}', renderT)">${DEL_SVG}</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      window.renderS = function() {
        document.getElementById('tableS').innerHTML = dataS.map(d => `
          <tr>
            <td style="font-family:var(--font-mono)">${d.order}</td>
            <td style="font-weight:700">${d.title}</td>
            <td style="color:var(--text-muted);font-size:0.8rem">${d.duration || '—'}</td>
            <td><span class="badge ${d.active ? 'badge--ok' : 'badge--wait'}">${d.active ? 'Ativo' : 'Off'}</span></td>
            <td>
              <div class="row-actions">
                <button class="btn-icon" onclick="editS('${d.$id}')">${EDIT_SVG}</button>
                <button class="btn-icon" onclick="deleteDoc('${COLLECTIONS.s}', '${d.$id}', renderS)">${DEL_SVG}</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      window.renderP = function() {
        document.getElementById('tableP').innerHTML = dataP.map(d => `
          <tr>
            <td style="font-weight:700">${d.title}</td>
            <td style="font-family:var(--font-mono);font-size:0.75rem">${d.category}</td>
            <td style="color:var(--text-muted);font-size:0.8rem">${d.published_at ? new Date(d.published_at).toLocaleDateString() : '—'}</td>
            <td><span class="badge ${d.published ? 'badge--ok' : 'badge--wait'}">${d.published ? 'Live' : 'Draft'}</span></td>
            <td>
              <div class="row-actions">
                <button class="btn-icon" onclick="editP('${d.$id}')">${EDIT_SVG}</button>
                <a href="/blog/${d.slug}" target="_blank" class="btn-icon">${LINK_SVG}</a>
                <button class="btn-icon" onclick="deleteDoc('${COLLECTIONS.p}', '${d.$id}', renderP)">${DEL_SVG}</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      window.renderQ = function() {
        document.getElementById('tableQ').innerHTML = dataQ.map(d => `
          <tr>
            <td style="font-family:var(--font-mono)">${d.order}</td>
            <td style="text-transform:uppercase;font-size:0.75rem;font-weight:700">${d.page}</td>
            <td style="font-weight:700">${d.question}</td>
            <td><span class="badge ${d.active ? 'badge--ok' : 'badge--wait'}">${d.active ? 'Ativo' : 'Off'}</span></td>
            <td>
              <div class="row-actions">
                <button class="btn-icon" onclick="editQ('${d.$id}')">${EDIT_SVG}</button>
                <button class="btn-icon" onclick="deleteDoc('${COLLECTIONS.q}', '${d.$id}', renderQ)">${DEL_SVG}</button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      // MODALS & CRUD
      window.openModal = (id) => document.getElementById(id).classList.add('open');
      window.closeModal = (id) => document.getElementById(id).classList.remove('open');

      // TRATAMENTOS
      window.openT = () => {
        document.getElementById('formT').reset();
        document.getElementById('t_id').value = '';
        quillT.setContents([]);
        document.getElementById('titleT').textContent = 'Novo Tratamento';
        openModal('modalT');
      };

      window.editT = (id) => {
        const d = dataT.find(x => x.$id === id);
        document.getElementById('t_id').value = d.$id;
        document.getElementById('t_icon').value = d.icon || '';
        document.getElementById('t_order').value = d.order || 1;
        document.getElementById('t_title').value = d.title;
        document.getElementById('t_slug').value = d.slug || '';
        document.getElementById('t_subtitle').value = d.subtitle || '';
        document.getElementById('t_cover').value = d.cover_url || '';
        quillT.root.innerHTML = d.description || '';
        document.getElementById('t_dur').value = d.duration || '';
        document.getElementById('t_rec').value = d.recovery || '';
        document.getElementById('t_active').value = d.active.toString();
        document.getElementById('t_highlight').value = d.highlight.toString();
        document.getElementById('titleT').textContent = 'Editar Tratamento';
        openModal('modalT');
      };

      document.getElementById('formT').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('t_id').value;
        const data = {
          icon: document.getElementById('t_icon').value,
          order: parseInt(document.getElementById('t_order').value),
          title: document.getElementById('t_title').value,
          slug: document.getElementById('t_slug').value,
          subtitle: document.getElementById('t_subtitle').value,
          cover_url: document.getElementById('t_cover').value,
          description: quillT.root.innerHTML,
          duration: document.getElementById('t_dur').value,
          recovery: document.getElementById('t_rec').value,
          active: document.getElementById('t_active').value === 'true',
          highlight: document.getElementById('t_highlight').value === 'true'
        };
        try {
          if (id) await call(`/databases/${DB}/collections/${COLLECTIONS.t}/documents/${id}`, { method: 'PATCH', body: JSON.stringify({ data }) });
          else await call(`/databases/${DB}/collections/${COLLECTIONS.t}/documents`, { method: 'POST', body: JSON.stringify({ documentId: uniqueId(), data, permissions: [] }) });
          toast('Tratamento salvo com sucesso!'); closeModal('modalT'); loadAll(); loadStats();
        } catch (e) { 
          console.error(e);
          toast(`Erro: ${e.message}`, 'error'); 
        }
      });

      // CIRURGIAS
      window.openS = () => {
        document.getElementById('formS').reset();
        document.getElementById('s_id').value = '';
        quillS.setContents([]);
        document.getElementById('titleS').textContent = 'Nova Cirurgia';
        openModal('modalS');
      };

      window.editS = (id) => {
        const d = dataS.find(x => x.$id === id);
        document.getElementById('s_id').value = d.$id;
        document.getElementById('s_num').value = d.number || '';
        document.getElementById('s_order').value = d.order || 1;
        document.getElementById('s_title').value = d.title;
        document.getElementById('s_slug').value = d.slug || '';
        document.getElementById('s_cover').value = d.cover_url || '';
        quillS.root.innerHTML = d.description || '';
        document.getElementById('s_dur').value = d.duration || '';
        document.getElementById('s_rec').value = d.recovery || '';
        document.getElementById('s_ane').value = d.anesthesia || '';
        document.getElementById('s_active').value = d.active.toString();
        document.getElementById('titleS').textContent = 'Editar Cirurgia';
        openModal('modalS');
      };

      document.getElementById('formS').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('s_id').value;
        const data = {
          number: document.getElementById('s_num').value,
          order: parseInt(document.getElementById('s_order').value),
          title: document.getElementById('s_title').value,
          slug: document.getElementById('s_slug').value,
          cover_url: document.getElementById('s_cover').value,
          description: quillS.root.innerHTML,
          duration: document.getElementById('s_dur').value,
          recovery: document.getElementById('s_rec').value,
          anesthesia: document.getElementById('s_ane').value,
          active: document.getElementById('s_active').value === 'true'
        };
        try {
          if (id) await call(`/databases/${DB}/collections/${COLLECTIONS.s}/documents/${id}`, { method: 'PATCH', body: JSON.stringify({ data }) });
          else await call(`/databases/${DB}/collections/${COLLECTIONS.s}/documents`, { method: 'POST', body: JSON.stringify({ documentId: uniqueId(), data, permissions: [] }) });
          toast('Cirurgia salva com sucesso!'); closeModal('modalS'); loadAll(); loadStats();
        } catch (e) { 
          console.error(e);
          toast(`Erro: ${e.message}`, 'error'); 
        }
      });

      // BLOG
      window.openP = () => {
        document.getElementById('formP').reset();
        document.getElementById('p_id').value = '';
        quillP.setContents([]);
        quillExc.setContents([]);
        document.getElementById('titleP').textContent = 'Novo Post';
        openModal('modalP');
      };

      window.editP = (id) => {
        const d = dataP.find(x => x.$id === id);
        document.getElementById('p_id').value = d.$id;
        document.getElementById('p_title').value = d.title;
        document.getElementById('p_slug').value = d.slug;
        quillExc.root.innerHTML = d.excerpt || '';
        quillP.root.innerHTML = d.content || '';
        document.getElementById('p_cat').value = d.category;
        document.getElementById('p_date').value = d.published_at ? d.published_at.split('T')[0] : '';
        document.getElementById('p_img').value = d.cover_url || '';
        document.getElementById('p_pub').value = d.published.toString();
        document.getElementById('titleP').textContent = 'Editar Post';
        openModal('modalP');
      };


      document.getElementById('formP').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('p_id').value;
        const data = {
          title: document.getElementById('p_title').value,
          slug: document.getElementById('p_slug').value,
          excerpt: quillExc.root.innerHTML,
          content: quillP.root.innerHTML,
          category: document.getElementById('p_cat').value,
          published_at: document.getElementById('p_date').value ? new Date(document.getElementById('p_date').value).toISOString() : new Date().toISOString(),
          cover_url: document.getElementById('p_img').value,
          published: document.getElementById('p_pub').value === 'true'
        };
        try {
          if (id) await call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents/${id}`, { method: 'PATCH', body: JSON.stringify({ data }) });
          else await call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents`, { method: 'POST', body: JSON.stringify({ documentId: uniqueId(), data, permissions: [] }) });
          toast('Post salvo com sucesso!'); closeModal('modalP'); loadAll(); loadStats();
        } catch (e) { 
          console.error(e);
          toast(`Erro: ${e.message}`, 'error'); 
        }
      });
      // QUIZ
      window.openQ = () => {
        document.getElementById('formQ').reset();
        document.getElementById('q_id').value = '';
        document.getElementById('titleQ').textContent = 'Nova Pergunta';
        openModal('modalQ');
      };

      window.editQ = (id) => {
        const d = dataQ.find(x => x.$id === id);
        document.getElementById('q_id').value = d.$id;
        document.getElementById('q_page').value = d.page;
        document.getElementById('q_order').value = d.order || 1;
        document.getElementById('q_question').value = d.question;
        document.getElementById('q_answer').value = d.answer;
        document.getElementById('q_active').value = d.active.toString();
        document.getElementById('titleQ').textContent = 'Editar Pergunta';
        openModal('modalQ');
      };

      document.getElementById('formQ').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('q_id').value;
        const data = {
          page: document.getElementById('q_page').value,
          order: parseInt(document.getElementById('q_order').value),
          question: document.getElementById('q_question').value,
          answer: document.getElementById('q_answer').value,
          active: document.getElementById('q_active').value === 'true'
        };
        try {
          if (id) await call(`/databases/${DB}/collections/${COLLECTIONS.q}/documents/${id}`, { method: 'PATCH', body: JSON.stringify({ data }) });
          else await call(`/databases/${DB}/collections/${COLLECTIONS.q}/documents`, { method: 'POST', body: JSON.stringify({ documentId: uniqueId(), data, permissions: [] }) });
          toast('Pergunta salva com sucesso!'); closeModal('modalQ'); loadAll(); loadStats();
        } catch (e) { 
          toast(`Erro: ${e.message}`, 'error'); 
        }
      });

      window.seedQuiz = async () => {
        if (!confirm('Deseja importar as 4 perguntas originais de Cirurgias para o banco de dados?')) return;
        const btn = document.getElementById('btnSeed');
        btn.disabled = true;
        btn.textContent = 'Importando...';

        const defaults = [
          { q: 'As cirurgias vasculares têm risco?', a: 'Como qualquer procedimento cirúrgico, há riscos. Porém, com avaliação pré-operatória cuidadosa, equipe especializada e tecnologia moderna, os riscos são minimizados. A Dra. Mônica discute todos os aspectos na consulta.', p: 'cirurgias', o: 1 },
          { q: 'As cirurgias deixam cicatrizes visíveis?', a: 'Técnicas como a microcirurgia de varizes e a ablação laser endovenosa deixam cicatrizes mínimas ou imperceptíveis. Cada caso é avaliado individualmente para escolher a abordagem menos invasiva.', p: 'cirurgias', o: 2 },
          { q: 'Qual a recuperação após a cirurgia?', a: 'Depende do procedimento. Técnicas minimamente invasivas permitem retorno às atividades em 3–7 dias. Cirurgias mais extensas podem exigir repouso de até 21 dias com acompanhamento ambulatorial.', p: 'cirurgias', o: 3 },
          { q: 'O plano de saúde cobre as cirurgias?', a: 'A maioria dos planos de saúde cobre procedimentos cirúrgicos vasculares com indicação médica. Nossa equipe pode auxiliar com a documentação necessária para autorização.', p: 'cirurgias', o: 4 }
        ];

        try {
          for (const item of defaults) {
            await call(`/databases/${DB}/collections/${COLLECTIONS.q}/documents`, { 
              method: 'POST', 
              body: JSON.stringify({ 
                documentId: uniqueId(), 
                data: {
                  question: item.q,
                  answer: item.a,
                  page: item.p,
                  order: item.o,
                  active: true
                }, 
                permissions: [] 
              }) 
            });
          }
          toast('Perguntas importadas com sucesso!');
          loadAll();
        } catch (e) {
          console.error(e);
          toast('Erro: ' + e.message);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Importar Perguntas Padrão';
        }
      };
      // DELETE UNIVERSAL
      window.deleteDoc = async (coll, id, callback) => {
        if (!confirm('Tem certeza que deseja excluir?')) return;
        try {
          await call(`/databases/${DB}/collections/${coll}/documents/${id}`, { method: 'DELETE' });
          toast('Excluído com sucesso!'); loadAll(); loadStats();
        } catch (e) { toast('Erro ao excluir'); }
      }

      // MIGRACAO CATEGORIAS
      window.migrateCategories = async () => {
        if (!confirm('Isto moverá os posts da aba Blog que possuem a categoria "Tratamentos" ou "Cirurgia" para suas respectivas abas. Continuar?')) return;
        toast('Iniciando migração... aguarde.');
        try {
          const res = await call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents?limit=100`);
          let countT = 0, countC = 0;
          for (const post of res.documents) {
            const cat = post.category ? post.category.toLowerCase() : '';
            if (cat.includes('tratamento')) {
              await call(`/databases/${DB}/collections/${COLLECTIONS.t}/documents`, { 
                method: 'POST', 
                body: JSON.stringify({ documentId: uniqueId(), data: { title: post.title, slug: post.slug, cover_url: post.cover_url || '', description: post.content || '', subtitle: post.excerpt || '', active: post.published !== false, order: 99, highlight: false }, permissions: [] }) 
              });
              await call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents/${post.$id}`, { method: 'DELETE' });
              countT++;
            } else if (cat.includes('cirurgia')) {
              await call(`/databases/${DB}/collections/${COLLECTIONS.s}/documents`, { 
                method: 'POST', 
                body: JSON.stringify({ documentId: uniqueId(), data: { title: post.title, slug: post.slug, cover_url: post.cover_url || '', description: post.content || '', active: post.published !== false, order: 99 }, permissions: [] }) 
              });
              await call(`/databases/${DB}/collections/${COLLECTIONS.p}/documents/${post.$id}`, { method: 'DELETE' });
              countC++;
            }
          }
          toast(`Sucesso! ${countT} tratamentos e ${countC} cirurgias organizados.`);
          loadAll(); loadStats();
        } catch (e) {
          console.error(e);
          toast('Erro: ' + e.message, 'error');
        }
      };

      // SETTINGS — Campos mapeados
      const SETTINGS_FIELDS = [
        'whatsapp','phone','email',
        'address','city','cep','maps',
        'hours_weekday','hours_sat','hours_sun','hours_obs',
        'instagram','facebook','youtube','linkedin',
        'maps_embed'
      ];

      window.loadSettings = async function() {
        try {
          const doc = await call(`/databases/${DB}/collections/${COLLECTIONS.cfg}/documents/${SETTINGS_DOC_ID}`);
          SETTINGS_FIELDS.forEach(key => {
            const el = document.getElementById(`cfg_${key}`);
            if (el && doc[key] !== undefined) el.value = doc[key] || '';
          });
        } catch(e) {
          // Documento ainda não existe — campos ficam vazios
          console.info('site_settings ainda não criado.');
        }
      };

      window.saveSettings = async function() {
        const btn = document.getElementById('btnSaveSettings');
        btn.disabled = true;
        btn.textContent = 'Salvando...';
        const data = {};
        SETTINGS_FIELDS.forEach(key => {
          const el = document.getElementById(`cfg_${key}`);
          if (el) data[key] = el.value.trim();
        });
        try {
          // Tenta atualizar; se não existir, cria com ID fixo
          try {
            await call(`/databases/${DB}/collections/${COLLECTIONS.cfg}/documents/${SETTINGS_DOC_ID}`, {
              method: 'PATCH',
              body: JSON.stringify({ data })
            });
          } catch(err) {
            if (err.message && (err.message.includes('not found') || err.message.includes('404') || err.message.includes('Document'))) {
              await call(`/databases/${DB}/collections/${COLLECTIONS.cfg}/documents`, {
                method: 'POST',
                body: JSON.stringify({ documentId: SETTINGS_DOC_ID, data, permissions: [] })
              });
            } else { throw err; }
          }
          toast('✅ Configurações salvas com sucesso!');
        } catch(e) {
          console.error(e);
          toast('Erro ao salvar: ' + e.message);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Salvar Configurações';
          btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Salvar Configurações`;
        }
      };

      window.previewMap = function() {
        const src = document.getElementById('cfg_maps_embed').value.trim();
        if (!src) { toast('Cole o link do iframe do Google Maps primeiro.'); return; }
        const preview = document.getElementById('mapPreview');
        document.getElementById('mapFrame').src = src;
        preview.style.display = 'block';
      };

      // LOGOUT
      document.getElementById('logoutBtn').addEventListener('click', async () => {
        try { await call('/account/sessions/current', { method: 'DELETE' }); } catch(e) {}
        localStorage.removeItem('cookieFallback');
        window.location.replace('/admin');
      });
    </script>
  </body>
</html>
