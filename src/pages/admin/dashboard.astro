          >&times;</button
        ><h2 id="titleQ">Pergunta</h2><form id="formQ">
          <input type="hidden" id="q_id" /><div class="form-grid">
            <div class="field">
              <label>Página</label><select id="q_page"
                ><option value="home">Home</option><option value="tratamentos"
                  >Tratamentos</option
                ><option value="cirurgias">Cirurgias</option></select
              >
            </div><div class="field">
              <label>Ordem</label><input type="number" id="q_order" value="1" />
            </div><div class="field full">
              <label>Pergunta</label><input id="q_question" required />
            </div><div class="field full">
