---
// Autenticação verificada no client-side via Appwrite SDK
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — Spazio Vascolare Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Quill WYSIWYG -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js" is:inline></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Urbanist:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;700&display=swap" rel="stylesheet" />

    <style>
      :root {
        /* Satin Tech Palette */
        --bg: #fff8f9;
        --surface: #ffffff;
        --surface-glass: rgba(255, 255, 255, 0.7);
        
        --accent: #d40a5b;
        --accent-glow: rgba(212, 10, 91, 0.15);
        --accent-deep: #810a37;
        
        --text: #410213;
        --text-muted: #d40a5b;
        --border: rgba(212, 10, 91, 0.12);
        --border-bright: rgba(212, 10, 91, 0.25);
        
        --font-display: "Urbanist", sans-serif;
        --font-mono: "Space Grotesk", monospace;
        --font-body: "Urbanist", sans-serif;
        
        --radius: 24px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
        --dur: 0.4s;
        --sidebar-w: 280px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      html, body { 
        min-height: 100vh;
        background-color: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      body {
        background: 
          linear-gradient(rgba(255, 248, 249, 0.5), rgba(255, 248, 249, 0.5)),
          url("/img/fundo-1388026885-1024x1024.jpg");
        background-attachment: fixed;
        background-size: cover;
        background-position: center;
      }

      /* Layout */
      .app {
        display: grid;
        grid-template-columns: var(--sidebar-w) 1fr;
        min-height: 100vh;
      }

      /* Sidebar */
      .sidebar {
        background: var(--surface-glass);
        backdrop-filter: blur(12px);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 0;
        height: 100vh;
        z-index: 20;
      }

      .sidebar__logo {
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
      }

      .sidebar__logo img { width: 42px; height: 42px; border-radius: 12px; object-fit: cover; border: 1px solid var(--accent); }
      .sidebar__logo-text { line-height: 1.1; }
      .sidebar__logo-name { font-family: var(--font-display); font-weight: 900; font-size: 1rem; letter-spacing: 0.05em; }
      .sidebar__logo-sub { font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); text-transform: uppercase; font-weight: 700; }

      .sidebar__nav { padding: 1.5rem 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
      .nav-label { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; color: var(--text-muted); padding: 1rem 1rem 0.5rem; opacity: 0.6; letter-spacing: 0.1em; }
      
      .nav-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.85rem 1.25rem;
        border-radius: 16px;
        color: var(--text);
        text-decoration: none;
        font-weight: 600;
        transition: all var(--dur) var(--ease);
        border: 1px solid transparent;
        background: transparent;
        cursor: pointer;
        width: 100%;
        text-align: left;
      }

      .nav-link:hover { background: var(--accent-glow); color: var(--accent); }
      .nav-link.active { background: var(--surface); border-color: var(--accent); color: var(--accent); box-shadow: 0 4px 15px var(--accent-glow); }

      /* Main Content */
      .main { display: flex; flex-direction: column; }
      .topbar {
        padding: 1.5rem 2.5rem;
        background: var(--surface-glass);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .topbar h1 { font-size: 1.25rem; font-weight: 800; font-family: var(--font-display); }

      .content { padding: 2.5rem; flex: 1; }
      
      .tab-section { display: none; animation: fadeIn 0.4s var(--ease); }
      .tab-section.active { display: block; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

      /* Stats */
      .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 3rem; }
      .stat-card {
        background: var(--surface-glass);
        backdrop-filter: blur(10px);
        padding: 2rem;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: transform 0.3s;
      }
      .stat-card:hover { transform: translateY(-5px); border-color: var(--accent); }
      .stat-card__val { font-size: 2.5rem; font-weight: 900; color: var(--accent); line-height: 1; font-family: var(--font-display); }
      .stat-card__label { font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 700; }

      /* Section Header & Buttons */
      .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
      .btn-primary {
        background: var(--accent);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 100px;
        font-weight: 700;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s;
        box-shadow: 0 4px 15px var(--accent-glow);
      }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px var(--accent-glow); background: var(--accent-deep); }

      /* Tables */
      /* Tables (Global selectors to work with JS injection) */
      :global(.glass-card) { background: var(--surface-glass); backdrop-filter: blur(20px); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; }
      :global(table) { width: 100%; border-collapse: collapse; }
      :global(th), :global(td) { padding: 1.25rem 1.5rem; text-align: left; border-bottom: 1px solid var(--border); }
      :global(th) { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; font-weight: 700; background: rgba(212, 10, 91, 0.03); }
      :global(th:first-child), :global(td:first-child) { padding-left: 2.5rem !important; }
      :global(th:last-child), :global(td:last-child) { padding-right: 2.5rem !important; }
      :global(tr:last-child td) { border-bottom: none; }
      :global(tr:hover td) { background: rgba(212, 10, 91, 0.02); }

      .badge { padding: 0.3rem 0.8rem; border-radius: 100px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
      .badge--ok { background: rgba(16, 185, 129, 0.1); color: #10b981; }
      .badge--wait { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }

      .row-actions { display: flex; gap: 0.5rem; }
      .btn-icon { width: 36px; height: 36px; border-radius: 12px; border: 1px solid var(--border); background: var(--surface); color: var(--text); display: flex; align-items: center; justify-content: center; transition: 0.2s; cursor: pointer; }
      .btn-icon:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }

      /* Modals */
      .modal-overlay { position: fixed; inset: 0; background: rgba(65, 2, 19, 0.4); backdrop-filter: blur(12px); z-index: 100; display: none; align-items: center; justify-content: center; padding: 2rem; }
      .modal-overlay.open { display: flex; }
      .modal { background: var(--surface); width: 100%; max-width: 700px; border-radius: 32px; border: 1px solid var(--accent); padding: 2.5rem; box-shadow: 0 20px 50px rgba(0,0,0,0.1); position: relative; max-height: 90vh; overflow-y: auto; }
      .modal h2 { margin-bottom: 1.5rem; font-size: 1.5rem; }
      .modal-close { position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; font-size: 1.5rem; color: var(--text-muted); cursor: pointer; }

      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .field { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
      .field.full { grid-column: span 2; }
      label { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); font-weight: 700; }
      input, textarea, select { 
        padding: 1rem; border: 1.5px solid var(--border); border-radius: 14px; background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 0.95rem; outline: none; transition: 0.2s; 
      }
      input:focus, textarea:focus, .ql-container:focus { border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-glow); }
      textarea { resize: vertical; min-height: 120px; }
      
      /* Quill overrides */
      .ql-toolbar.ql-snow { border-color: var(--border); border-radius: 14px 14px 0 0; background: var(--surface); }
      .ql-container.ql-snow { border-color: var(--border); border-radius: 0 0 14px 14px; min-height: 200px; font-family: var(--font-body); font-size: 1rem; }
      .ql-editor { min-height: 200px; }
      .ql-editor.ql-blank::before { color: var(--text-muted); font-style: normal; }

      .modal-footer { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
      .btn-sec { background: var(--bg); border: 1px solid var(--border); padding: 0.75rem 1.5rem; border-radius: 100px; font-weight: 600; cursor: pointer; }

      /* Toasts */
      .toast-container { position: fixed; bottom: 2rem; right: 2rem; z-index: 1000; display: flex; flex-direction: column; gap: 0.75rem; }
      .toast { background: var(--surface); border: 1px solid var(--accent); padding: 1rem 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(212, 10, 91, 0.15); font-weight: 700; animation: slideIn 0.3s var(--ease); }
      @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

      /* Loading */
      #loader { position: fixed; inset: 0; background: var(--bg); z-index: 2000; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; transition: opacity 0.5s; }
      #loader.hidden { opacity: 0; pointer-events: none; }
      .spinner { width: 40px; height: 40px; border: 4px solid var(--accent-glow); border-top-color: var(--accent); border-radius: 50%; animation: spin 1s infinite linear; }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>

  <body>
    <div id="loader"><div class="spinner"></div><div style="font-family:var(--font-mono);font-size:0.8rem;letter-spacing:0.2em;color:var(--accent)">AUTENTICANDO...</div></div>

    <div class="app">
      <aside class="sidebar">
        <div class="sidebar__logo">
          <img src="/img/logo-i-200px.jpg" alt="Spazio" />
          <div class="sidebar__logo-text">
            <div class="sidebar__logo-name">SPAZIO VASCOLARE</div>
            <div class="sidebar__logo-sub">Gerenciamento</div>
          </div>
        </div>
        
        <nav class="sidebar__nav">
          <div class="nav-label">Overview</div>
          <button class="nav-link active" data-tab="dash">Dashboard</button>
          
          <div class="nav-label">Conteúdo do Site</div>
          <button class="nav-link" data-tab="treatments">Tratamentos</button>
          <button class="nav-link" data-tab="surgeries">Cirurgias</button>
          <button class="nav-link" data-tab="blog">Blog Posts</button>
          <button class="nav-link" data-tab="quiz">Quiz Geral</button>

          <div class="nav-label">Configurações</div>
          <button class="nav-link" data-tab="settings">Info Contato</button>
        </nav>
        
        <div style="padding:1.5rem; border-top:1px solid var(--border)">
          <button class="nav-link" id="logoutBtn" style="color:var(--red)">Sair do Painel</button>
        </div>
      </aside>

      <main class="main">
        <header class="topbar">
          <h1 id="tabTitle">Dashboard</h1>
          <div style="display:flex;align-items:center;gap:1rem">
            <span id="userEmail" style="font-weight:700;font-size:0.85rem;color:var(--text-muted)"></span>
            <div style="width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 10px #10b981"></div>
          </div>
        </header>

        <div class="content">
          <!-- DASHBOARD OVERVIEW -->
          <section id="tab-dash" class="tab-section active">
            <div class="stats-grid">
              <div class="stat-card">
                <div class="stat-card__val" id="count-t">0</div>
                <div class="stat-card__label">Tratamentos</div>
              </div>
              <div class="stat-card">
                <div class="stat-card__val" id="count-s">0</div>
                <div class="stat-card__label">Cirurgias</div>
              </div>
              <div class="stat-card">
                <div class="stat-card__val" id="count-p">0</div>
                <div class="stat-card__label">Blog Posts</div>
              </div>
              <div class="stat-card">
                <div class="stat-card__val" id="count-q">0</div>
                <div class="stat-card__label">Perguntas Quiz</div>
              </div>
            </div>
            
            <div class="glass-card" style="padding:3rem;text-align:center">
              <h2 style="font-family:var(--font-display);font-size:2rem;margin-bottom:1rem">Bem-vindo ao Novo Painel</h2>
              <p style="max-width:600px;margin:0 auto">Utilize o menu lateral para gerenciar os conteúdos do site Spazio Vascolare. Todas as alterações são sincronizadas em tempo real com o backend.</p>
              <br><br>
              <button class="btn-primary" onclick="window.migrateCategories()" style="background:#10b981">Executar Migração (Mover Tratamentos e Cirurgias)</button>
            </div>
          </section>

          <!-- TREATMENTS TAB -->
          <section id="tab-treatments" class="tab-section">
            <div class="section-header">
              <h2>Gerenciar Tratamentos</h2>
              <button class="btn-primary" onclick="openModal('modalT')">Novo Tratamento</button>
            </div>
            <div class="glass-card">
              <table>
                <thead>
                  <tr>
                    <th>Ordem</th>
                    <th>Título</th>
                    <th>Subtítulo</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="tableT"></tbody>
              </table>
            </div>
          </section>

          <!-- SURGERIES TAB -->
          <section id="tab-surgeries" class="tab-section">
            <div class="section-header">
              <h2>Gerenciar Cirurgias</h2>
              <button class="btn-primary" onclick="openModal('modalS')">Nova Cirurgia</button>
            </div>
            <div class="glass-card">
              <table>
                <thead>
                  <tr>
                    <th>Ordem</th>
                    <th>Título</th>
                    <th>Duração</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="tableS"></tbody>
              </table>
            </div>
          </section>

          <!-- BLOG TAB -->
          <section id="tab-blog" class="tab-section">
            <div class="section-header">
              <h2>Gerenciar Blog</h2>
              <button class="btn-primary" onclick="openModal('modalP')">Novo Artigo</button>
            </div>
            <div class="glass-card">
              <table>
                <thead>
                  <tr>
                    <th>Título</th>
                    <th>Categoria</th>
                    <th>Publicação</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="tableP"></tbody>
              </table>
            </div>
          </section>

          <!-- QUIZ TAB -->
          <section id="tab-quiz" class="tab-section">
            <div class="section-header">
              <h2>Gerenciar Quiz Geral (FAQ)</h2>
              <div style="display:flex; gap:1rem">
                <button class="btn-sec" onclick="seedQuiz()" id="btnSeed">Importar Perguntas Padrão</button>
                <button class="btn-primary" onclick="openQ()">Nova Pergunta</button>
              </div>
            </div>
            <div class="glass-card">
              <table>
                <thead>
                  <tr>
                    <th>Ordem</th>
                    <th>Página</th>
                    <th>Pergunta</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="tableQ"></tbody>
              </table>
            </div>
          </section>

          <!-- SETTINGS TAB -->
          <section id="tab-settings" class="tab-section">
            <div class="section-header">
              <h2>Informações de Contato</h2>
              <button class="btn-primary" onclick="saveSettings()" id="btnSaveSettings">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Salvar Configurações
              </button>
            </div>

            <div class="settings-grid">
              <!-- Contato Direto -->
              <div class="settings-card glass-card">
                <div class="settings-card__header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.7 19.79 19.79 0 0 1 1.6 5.1 2 2 0 0 1 3.58 3h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 10.64a16 16 0 0 0 6 6l1.06-1.06a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 17z"/></svg>
                  <h3>Contato Direto</h3>
                </div>
                <div class="field"><label>WhatsApp (com DDI, ex: 5543991502223)</label><input id="cfg_whatsapp" placeholder="5543991502223" /></div>
                <div class="field"><label>Telefone Fixo</label><input id="cfg_phone" placeholder="(43) 3377-1900" /></div>
                <div class="field"><label>E-mail</label><input id="cfg_email" type="email" placeholder="contato@spaziovascolare.com.br" /></div>
              </div>

              <!-- Endereço -->
              <div class="settings-card glass-card">
                <div class="settings-card__header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <h3>Endereço & Localização</h3>
                </div>
                <div class="field"><label>Endereço Completo</label><input id="cfg_address" placeholder="Rua Exemplo, 123 — Sala 45" /></div>
                <div class="field"><label>Bairro / Cidade</label><input id="cfg_city" placeholder="Centro — Londrina/PR" /></div>
                <div class="field"><label>CEP</label><input id="cfg_cep" placeholder="86010-000" /></div>
                <div class="field"><label>Link Google Maps (URL curta ou embed src)</label><input id="cfg_maps" placeholder="https://maps.google.com/?q=..." /></div>
              </div>

              <!-- Horários -->
              <div class="settings-card glass-card">
                <div class="settings-card__header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <h3>Horários de Atendimento</h3>
                </div>
                <div class="field"><label>Segunda a Sexta</label><input id="cfg_hours_weekday" placeholder="08h – 18h" /></div>
                <div class="field"><label>Sábado</label><input id="cfg_hours_sat" placeholder="08h – 12h" /></div>
                <div class="field"><label>Domingo / Feriados</label><input id="cfg_hours_sun" placeholder="Fechado" /></div>
                <div class="field"><label>Observação (ex: Atendimentos por agendamento)</label><input id="cfg_hours_obs" placeholder="Somente com agendamento prévio" /></div>
              </div>

              <!-- Redes Sociais -->
              <div class="settings-card glass-card">
                <div class="settings-card__header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M17 2H7a5 5 0 0 0-5 5v10a5 5 0 0 0 5 5h10a5 5 0 0 0 5-5V7a5 5 0 0 0-5-5z"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  <h3>Redes Sociais</h3>
                </div>
                <div class="field"><label>Instagram (URL completa)</label><input id="cfg_instagram" placeholder="https://instagram.com/spaziovascolare" /></div>
                <div class="field"><label>Facebook (URL completa)</label><input id="cfg_facebook" placeholder="https://facebook.com/spaziovascolare" /></div>
                <div class="field"><label>YouTube (URL completa)</label><input id="cfg_youtube" placeholder="https://youtube.com/@spaziovascolare" /></div>
                <div class="field"><label>LinkedIn (URL completa)</label><input id="cfg_linkedin" placeholder="https://linkedin.com/in/monicaarena" /></div>
              </div>

              <!-- Google Maps Embed Preview -->
              <div class="settings-card glass-card" style="grid-column: span 2;">
                <div class="settings-card__header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                  <h3>Embed do Google Maps</h3>
                </div>
                <div class="field"><label>Código iframe do Google Maps (cole o src do iframe de embed)</label><input id="cfg_maps_embed" placeholder="https://www.google.com/maps/embed?pb=..." /></div>
                <button type="button" class="btn-sec" onclick="previewMap()" style="margin-top:0.5rem">Pré-visualizar Mapa</button>
                <div id="mapPreview" style="margin-top:1rem;border-radius:16px;overflow:hidden;display:none;height:300px;">
                  <iframe id="mapFrame" width="100%" height="300" style="border:0;" allowfullscreen loading="lazy"></iframe>
                </div>
              </div>
            </div>

