---
title: "Recuperar Senha"
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recuperar Senha — Admin</title>
  <link rel="icon" type="image/jpeg" href="/img/logo-i-200px.jpg" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Urbanist:wght@700;800;900&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root {
      --bg:#fff8f9; --accent:#d40a5b; --text:#410213; --text-muted:#8a3048; --border:rgba(212,10,91,0.12);
      --font-display:'Urbanist',sans-serif; --font-body:'Plus Jakarta Sans',sans-serif;
    }
    html,body { min-height:100vh; background:var(--bg); font-family:var(--font-body); display:flex; align-items:center; justify-content:center; }
    .card{ max-width:420px; width:100%; background:rgba(255,255,255,0.75); backdrop-filter:blur(20px); border-radius:20px; padding:2rem; box-shadow:0 10px 30px rgba(212,10,91,0.1); }
    h1{ font-family:var(--font-display); font-size:1.8rem; color:var(--text); margin-bottom:0.5rem; }
    .form-group{ margin-bottom:1rem; display:flex; flex-direction:column; }
    label{ font-size:0.85rem; color:var(--text-muted); margin-bottom:0.25rem; }
    input{ padding:0.8rem 1rem; border:1.5px solid var(--border); border-radius:12px; }
    button{ width:100%; padding:0.8rem; background:var(--accent); color:#fff; border:none; border-radius:12px; cursor:pointer; }
    .msg{ margin-top:1rem; color:var(--accent); }
  </style>
</head>
<body>
  <div class="card">
    <h1>Recuperar Senha</h1>
    <p>Insira o e‑mail da conta de administrador para receber um link de redefinição.</p>
    <form id="recoveryForm">
      <div class="form-group">
        <label for="email">E‑mail</label>
        <input type="email" id="email" required />
      </div>
      <button type="submit">Enviar link de recuperação</button>
    </form>
    <div class="msg" id="msg"></div>
  </div>

  <script>
    import { call } from '../../lib/dashboard-api.ts';
    const form = document.getElementById('recoveryForm');
    const msg = document.getElementById('msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const email = emailInput?.value.trim();
      if (!email) return;

      try {
        const redirect = `${window.location.origin}/admin/reset-password`;
        await call(`/account/recovery?email=${encodeURIComponent(email)}&url=${encodeURIComponent(redirect)}`, { method: 'POST' });
        if (msg) msg.textContent = 'E‑mail de recuperação enviado. Verifique sua caixa de entrada.';
      } catch (err) {
        console.error(err);
        if (msg) msg.textContent = 'Erro ao solicitar recuperação. Tente novamente.';
      }
    });
  </script>
</body>
</html>
