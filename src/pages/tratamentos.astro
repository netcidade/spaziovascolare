---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import { STATIC_TREATMENTS } from "../lib/staticData";

// Tenta buscar do Appwrite; usa estático como fallback
let treatments = STATIC_TREATMENTS;
try {
  const { getTreatments } = await import("../lib/appwrite");
  const liveT = await getTreatments();
  if (liveT.length > 0) treatments = liveT as typeof STATIC_TREATMENTS;
} catch (_) {
  // usa fallback estático
}
---

<Layout
  title="Tratamentos Vasculares — Dra. Mônica Arena"
  description="Conheça todos os tratamentos vasculares oferecidos pela Dra. Mônica Arena em Londrina: varizes, laser, escleroterapia, trombose e muito mais."
>
  <Header />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Início</a>
          <span>/</span>
          <span>Tratamentos</span>
        </div>
        <div class="page-hero__content">
          <div class="section-meta">Especialidades Clínicas</div>
          <h1 class="page-hero__title">
            Tratamentos com<br />
            <span class="text-gradient">Tecnologia Avançada</span>
          </h1>
          <p class="page-hero__desc">
            Do diagnóstico ao tratamento, a Dra. Mônica Arena oferece soluções
            vasculares completas — com segurança, inovação e cuidado
            personalizado. Fellowship internacional (Arizona Heart Institute —
            EUA).
          </p>
        </div>
      </div>
      <div class="page-hero__glow" aria-hidden="true"></div>
    </section>

    <!-- Treatments Grid -->
    <section class="treatments-full">
      <div class="container">
        <div class="treatments-list">
          {
            treatments.map((t, i) => (
              <article
                class={`treatment-row ${t.highlight ? "highlight" : ""}`}
                data-index={i}
              >
                <div class="treatment-row__flare" aria-hidden="true" />

                <a href={`/tratamentos/${t.slug}`} class="treatment-row__link">
                  <div class="treatment-row__content">
                    {(t as any).cover_url && (
                      <div class="treatment-row__image">
                        <img
                          src={(t as any).cover_url}
                          alt={t.title}
                          loading="lazy"
                        />
                      </div>
                    )}

                    <div class="treatment-row__text">
                      <div class="treatment-row__header">
                        <h2 class="treatment-row__title">{t.title}</h2>
                        <p class="treatment-row__subtitle">{t.subtitle}</p>
                      </div>

                      <div class="treatment-row__desc" set:html={t.description || (t as any).desc || ""} />

                      <div class="treatment-row__meta">
                        {t.duration && (
                          <div class="meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                            </svg>
                            Duração: {t.duration}
                          </div>
                        )}
                        {t.recovery && (
                          <div class="meta-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
                            </svg>
                            Recuperação: {t.recovery}
                          </div>
                        )}
                      </div>

                      <div class="treatment-row__footer">
                        <span class="btn-read-more-ui">
                          Saiba mais sobre este tratamento
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14m-7-7 7 7-7 7"/>
                          </svg>
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
            ))
          }
        </div>

        <!-- FAQ -->
        <FAQ page="tratamentos" title="Dúvidas Frequentes" subtitle="Sobre nossos tratamentos" />

        <!-- CTA section -->
        <div class="treatments-cta glass">
          <div class="treatments-cta__text">
            <h3>Não sabe qual tratamento é ideal para você?</h3>
            <p>
              A Dra. Mônica realiza avaliação completa com ecografia vascular na
              mesma consulta.
            </p>
          </div>
          <div class="treatments-cta__actions">
            <a
              href="https://wa.me/5543991502223?text=Olá%2C%20gostaria%20de%20saber%20qual%20tratamento%20é%20indicado"
              class="btn-tech"
              target="_blank"
              rel="noopener noreferrer"
            >
              Falar com especialista
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M5 12h14m-7-7 7 7-7 7"></path>
              </svg>
            </a>
            <a href="tel:+554333771900" class="btn-secondary">(43) 3377-1900</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Page Hero ─────────────────────────────── */
  .page-hero {
    padding-top: 10rem;
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-hero__content {
    max-width: 700px;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .page-hero__desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 58ch;
  }

  .page-hero__glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(212, 10, 91, 0.06) 0%,
      transparent 65%
    );
    pointer-events: none;
  }

  /* ── Treatments List ──────────────────────── */
  .treatments-full {
    padding-bottom: var(--space-xl, 7rem);
  }

  .treatments-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .treatment-row {
    position: relative;
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .treatment-row:hover {
    border-color: var(--accent);
    background: #fff;
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(212, 10, 91, 0.1);
  }

  .treatment-row__content {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .treatment-row__image {
    flex-shrink: 0;
    width: 420px;
    height: 300px;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .treatment-row__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .treatment-row__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .treatment-row__title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 0.2rem;
  }

  .treatment-row__subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .treatment-row__desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .treatment-row__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .treatment-row__footer {
    display: flex;
    margin-top: auto;
  }

  .treatment-row__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .btn-read-more-ui {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s;
    border-bottom: 2px solid transparent;
  }

  .treatment-row:hover .btn-read-more-ui {
    gap: 1rem;
    border-bottom-color: var(--accent);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .treatment-row__flare {
    position: absolute;
    top: -80%;
    left: -30%;
    width: 160%;
    height: 160%;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(212, 10, 91, 0.06) 0%,
      transparent 60%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s;
  }

  .treatment-row:hover .treatment-row__flare {
    opacity: 1;
  }

  /* CTA */
  .treatments-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2.5rem 3rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(212, 10, 91, 0.15);
  }

  .treatments-cta__text h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .treatments-cta__text p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .treatments-cta__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .treatments-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .treatment-card.highlight {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .treatment-row__content {
      flex-direction: column;
      gap: 1.5rem;
    }
    .treatment-row__image {
      width: 100%;
      height: 240px;
    }
    .treatment-row__title {
      font-size: 1.8rem;
    }
    .treatments-cta {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }
    .treatments-cta__actions {
      width: 100%;
      flex-direction: column;
    }
    .treatments-cta__actions a {
      text-align: center;
      justify-content: center;
    }
  }
</style>

<script>
  // Staggered reveal
  const cards = document.querySelectorAll(".treatment-row");
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(
            () => {
              (e.target as HTMLElement).style.opacity = "1";
              (e.target as HTMLElement).style.transform = "translateY(0)";
            },
            Number((e.target as HTMLElement).dataset.index ?? 0) * 80,
          );
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 },
  );

  cards.forEach((card) => {
    (card as HTMLElement).style.opacity = "0";
    (card as HTMLElement).style.transform = "translateY(24px)";
    (card as HTMLElement).style.transition =
      "all 0.6s cubic-bezier(0.16,1,0.3,1)";
    obs.observe(card);
  });
</script>
