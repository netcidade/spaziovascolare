---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import FAQ from "../../components/FAQ.astro";
import Footer from "../../components/Footer.astro";
import { getTreatmentBySlug } from "../../lib/appwrite";

const { slug } = Astro.params;
const treatment = await getTreatmentBySlug(slug as string);

if (!treatment) {
  return Astro.redirect("/404");
}

const title = `${treatment.title} — Dra. Mônica Arena`;
const description = treatment.description.substring(0, 160);
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- Hero / Header -->
    <section class="item-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Início</a>
          <span>/</span>
          <a href="/tratamentos">Tratamentos</a>
          <span>/</span>
          <span>{treatment.title}</span>
        </div>
        
        <div class="hero-grid">
          <div class="hero-content">
            <div class="section-meta">Tratamento Especializado</div>
            <h1 class="hero-title">
              <span class="text-gradient">{treatment.title}</span>
            </h1>
            {treatment.subtitle && <p class="hero-subtitle" set:html={treatment.subtitle} />}
            
            <div class="hero-stats">
              {treatment.duration && (
                <div class="stat-item">
                  <span class="stat-label">Duração Média</span>
                  <span class="stat-val">{treatment.duration}</span>
                </div>
              )}
              {treatment.recovery && (
                <div class="stat-item">
                  <span class="stat-label">Recuperação</span>
                  <span class="stat-val">{treatment.recovery}</span>
                </div>
              )}
            </div>
          </div>
          
          <div class="hero-image glass">
            <img 
              src={treatment.cover_url || "/img/fundo-1388026885-1024x1024.jpg"} 
              alt={treatment.title}
            />
          </div>
        </div>
      </div>
      <div class="hero-bg-glow"></div>
    </section>

    <!-- Content -->
    <section class="item-body">
      <div class="container">
        <div class="content-wrapper glass">
          <div class="main-content">
            <div class="prose" set:html={treatment.description} />
          </div>
          
          <aside class="sidebar">
            <div class="contact-card glass">
              <h3>Agendar Avaliação</h3>
              <p>Fale com nossa equipe para tirar dúvidas ou marcar sua consulta.</p>
              <a href="https://wa.me/5543991502223" class="btn-secondary">
                WhatsApp
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FAQ 
      page="tratamentos" 
      title="Dúvidas Frequentes" 
      subtitle={`Sobre ${treatment.title}`}
    />
  </main>

  <Footer />
</Layout>

<style>
  .item-hero {
    padding-top: 10rem;
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .breadcrumb a { color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--accent); }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .stat-val {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .hero-image {
    border-radius: 40px;
    overflow: hidden;
    height: 500px;
    border: 1px solid var(--border);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bg-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, rgba(212, 10, 91, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .item-body { padding-bottom: 5rem; }

  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 3rem;
    padding: 4rem;
    border-radius: 40px;
    border: 1px solid var(--border);
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .sidebar { position: sticky; top: 10rem; height: fit-content; }

  .contact-card {
    padding: 2.5rem;
    border-radius: 30px;
    border: 1px solid var(--border);
    background: rgba(212, 10, 91, 0.03);
    text-align: center;
  }

  .contact-card h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .contact-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    .hero-image { aspect-ratio: 16/9; order: -1; height: auto; }
    .content-wrapper { grid-template-columns: 1fr; padding: 2.5rem; }
    .sidebar { position: static; }
  }
</style>
