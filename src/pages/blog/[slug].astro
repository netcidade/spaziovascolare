---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { STATIC_POSTS } from '../../lib/staticData';

const { slug } = Astro.params;

let post: typeof STATIC_POSTS[0] | null = null;
let relatedPosts: typeof STATIC_POSTS = [];

try {
  const { getPost, getPosts } = await import('../../lib/appwrite');
  post = await getPost(slug!);
  const all = await getPosts(10);
  relatedPosts = (all as typeof STATIC_POSTS).filter(p => p.slug !== slug).slice(0, 3);
} catch (_) {
  post = STATIC_POSTS.find(p => p.slug === slug) ?? null;
  relatedPosts = STATIC_POSTS.filter(p => p.slug !== slug).slice(0, 3);
}

if (!post) {
  return Astro.redirect('/blog', 302);
}

const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString('pt-BR', {
      day: '2-digit', month: 'long', year: 'numeric',
    })
  : '';
---

<Layout
  title={`${post.title} — Dra. Mônica Arena`}
  description={post.excerpt ?? ''}
  image={post.cover_url ?? undefined}
>
  <Header />

  <main>
    <!-- Article Hero -->
    <section class="article-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Início</a>
          <span>/</span>
          <a href="/blog">Blog</a>
          <span>/</span>
          <span>{post.title}</span>
        </div>

        <div class="article-meta">
          {post.category && <span class="article-cat">{post.category}</span>}
          {formattedDate && <time class="article-date" datetime={post.published_at ?? ''}>{formattedDate}</time>}
        </div>

        <h1 class="article-title">{post.title}</h1>
        <p class="article-excerpt">{post.excerpt}</p>

        <div class="article-author">
          <img
            src="/img/logo-i-200px.jpg"
            alt="Dra. Mônica Arena"
            width="42" height="42"
            class="author-avatar"
          />
          <div>
            <strong>Dra. Mônica Arena</strong>
            <span>Cirurgiã Vascular · Londrina/PR</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Cover image -->
    {post.cover_url && (
      <div class="article-cover-wrap container">
        <img
          src={post.cover_url}
          alt={post.title}
          class="article-cover"
          width="1200" height="630"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}

    <!-- Article content + sidebar -->
    <div class="article-layout container">
      <!-- Main content -->
      <article class="article-content glass">
        {post.content
          ? <div class="prose" set:html={post.content} />
          : (
            <div class="prose">
              <p>{post.excerpt}</p>
              <div class="content-placeholder">
                <p>
                  Este artigo será publicado em breve. Para saber mais sobre {post.title.toLowerCase()},
                  entre em contato com a Dra. Mônica Arena diretamente pelo WhatsApp.
                </p>
                <a
                  href={`https://wa.me/5543991502223?text=Olá%2C%20li%20sobre%20${encodeURIComponent(post.title)}%20e%20gostaria%20de%20saber%20mais`}
                  class="btn-secondary"
                  target="_blank" rel="noopener noreferrer"
                >
                  Falar com a especialista
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14m-7-7 7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          )
        }
      </article>

      <!-- Sidebar -->
      <aside class="article-sidebar">
        <!-- CTA Card -->
        <div class="sidebar-cta glass">
          <div class="sidebar-cta__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </div>
          <h3>Agende sua consulta</h3>
          <p>Atendimento personalizado com a Dra. Mônica Arena em Londrina.</p>
          <a
            href="https://wa.me/5543991502223"
            class="btn-secondary"
            target="_blank" rel="noopener noreferrer"
          >
            Agendar pelo WhatsApp
          </a>
          <a href="tel:+554333771900" class="sidebar-phone">(43) 3377-1900</a>
        </div>

        <!-- Share -->
        <div class="sidebar-share glass">
          <h4>Compartilhar</h4>
          <div class="share-buttons">
            <a
              href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.title + ' — ' + Astro.url.href)}`}
              target="_blank" rel="noopener noreferrer"
              class="share-btn share-btn--whatsapp"
              aria-label="Compartilhar no WhatsApp"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </aside>
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="related-posts container">
        <h2 class="related-title">Outros artigos</h2>
        <div class="related-grid">
          {relatedPosts.map(p => (
            <a href={`/blog/${p.slug}`} class="related-card glass">
              {p.category && <span class="related-cat">{p.category}</span>}
              <h3>{p.title}</h3>
              <p>{p.excerpt}</p>
              <span class="read-more">
                Ler
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14m-7-7 7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .article-hero {
    padding-top: 10rem;
    padding-bottom: 3rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .article-cat {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 1.25rem;
    max-width: 18ch;
  }

  .article-excerpt {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent);
  }

  .article-author strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  .article-author span {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Cover */
  .article-cover-wrap {
    margin-bottom: 3rem;
  }

  .article-cover {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 24px;
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
    margin-bottom: 5rem;
  }

  /* Article content */
  .article-content {
    padding: 3rem;
    border-radius: 24px;
    border: 1px solid rgba(212, 10, 91, 0.08);
  }

  .prose {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.85;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    margin: 2rem 0 1rem;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin: 1.5rem 0 0.75rem;
  }

  .prose :global(p) { margin-bottom: 1.25rem; }

  .prose :global(strong) { color: var(--text); font-weight: 700; }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .content-placeholder {
    margin-top: 2rem;
    padding: 2rem;
    background: rgba(212, 10, 91, 0.04);
    border-radius: 16px;
    border: 1px dashed rgba(212, 10, 91, 0.15);
  }

  .content-placeholder p { margin-bottom: 1.5rem; }

  /* Sidebar */
  .sidebar-cta {
    padding: 2rem;
    border-radius: 20px;
    border: 1px solid rgba(212, 10, 91, 0.15);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    text-align: center;
    align-items: center;
  }

  .sidebar-cta__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(212, 10, 91, 0.08);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-cta h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .sidebar-cta p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .sidebar-phone {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color 0.2s;
  }

  .sidebar-phone:hover { color: var(--accent); }

  .sidebar-share {
    padding: 1.5rem;
    border-radius: 20px;
    border: 1px solid rgba(212, 10, 91, 0.08);
  }

  .sidebar-share h4 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .share-buttons { display: flex; gap: 0.5rem; }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .share-btn--whatsapp {
    background: rgba(37, 211, 102, 0.1);
    color: #128c7e;
    border: 1px solid rgba(37, 211, 102, 0.2);
  }

  .share-btn--whatsapp:hover {
    background: #25D366;
    color: #fff;
    border-color: #25D366;
  }

  /* Related */
  .related-posts { padding-bottom: 5rem; }

  .related-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .related-card {
    padding: 1.75rem;
    border-radius: 20px;
    border: 1px solid rgba(212, 10, 91, 0.08);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.3s, border-color 0.3s;
  }

  .related-card:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 10, 91, 0.2);
  }

  .related-cat {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .related-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .related-card p {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .article-content { padding: 1.5rem; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
