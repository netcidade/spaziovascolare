---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const { category } = Astro.params;

let posts: any[] = [];
try {
  const { getPostsByCategory } = await import('../../../lib/appwrite');
  posts = await getPostsByCategory(category!);
} catch (_) {}

---

<Layout
  title={`${category} — Blog Spazio Vascolare`}
  description={`Artigos sobre ${category} escritos pela Dra. Mônica Arena.`}
>
  <Header />

  <main>
    <section class="category-hero">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Início</a>
          <span>/</span>
          <a href="/blog">Blog</a>
          <span>/</span>
          <span>{category}</span>
        </div>
        <div class="section-meta">Categoria</div>
        <h1 class="category-title">
          Artigos sobre<br />
          <span class="text-gradient">{category}</span>
        </h1>
      </div>
    </section>

    <section class="posts-section">
      <div class="container">
        {posts.length === 0 ? (
          <div class="empty-state glass">
             <p>Nenhum post encontrado nesta categoria.</p>
             <a href="/blog" class="btn-tech">Ver todos os posts</a>
          </div>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => (
              <article class="post-card">
                <a href={`/blog/${post.slug}`} class="post-card__link">
                  <div class="post-card__img-wrap">
                    <img
                      src={post.cover_url ?? '/img/fundo-1388026885-1024x1024.jpg'}
                      alt={post.title}
                      class="post-card__img"
                    />
                    <div class="post-card__img-overlay"></div>
                  </div>
                  <div class="post-card__body">
                    <h2 class="post-card__title">{post.title}</h2>
                    <p class="post-card__excerpt">{post.excerpt}</p>
                    <span class="read-more">Ler artigo</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .category-hero {
    padding-top: 10rem;
    padding-bottom: 3rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-family: var(--font-mono);
  }

  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }

  .category-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--text);
  }

  .posts-section { padding-bottom: 7rem; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .post-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(212, 10, 91, 0.08);
    background: #fff;
    transition: all 0.3s var(--ease);
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 12px 32px rgba(212, 10, 91, 0.08);
  }

  .post-card__link { text-decoration: none; color: inherit; }

  .post-card__img-wrap { aspect-ratio: 16/9; overflow: hidden; position: relative; }
  .post-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .post-card:hover .post-card__img { transform: scale(1.05); }

  .post-card__body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .post-card__title { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; color: var(--text); }
  .post-card__excerpt { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; }

  .read-more { font-size: 0.8rem; font-weight: 700; color: var(--accent); }

  .empty-state {
    padding: 5rem;
    text-align: center;
    border-radius: 24px;
    border: 1px dashed rgba(212, 10, 91, 0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
